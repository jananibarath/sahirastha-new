{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "base", "name": "Base", "color": "#ffffff" },
        { "slug": "contrast", "name": "Contrast", "color": "#12202f" },
        { "slug": "muted", "name": "Muted", "color": "#5a6672" },
        { "slug": "surface", "name": "Surface", "color": "#f4f7fa" },
        { "slug": "accent", "name": "Accent", "color": "#164a7c" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1120px"
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "20", "size": "0.5rem", "name": "2XS" },
        { "slug": "30", "size": "0.75rem", "name": "XS" },
        { "slug": "40", "size": "1rem", "name": "S" },
        { "slug": "50", "size": "1.5rem", "name": "M" },
        { "slug": "60", "size": "2rem", "name": "L" },
        { "slug": "70", "size": "3rem", "name": "XL" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
          "name": "System Sans",
          "slug": "system-sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.95rem", "name": "Small" },
        { "slug": "normal", "size": "1rem", "name": "Normal" },
        { "slug": "large", "size": "1.2rem", "name": "Large" },
        { "slug": "x-large", "size": "2rem", "name": "XL" }
      ]
    }
  },
  "styles": {
    "color": { "background": "var(--wp--preset--color--base)", "text": "var(--wp--preset--color--contrast)" },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "typography": { "lineHeight": "1.25", "fontWeight": "600" }
      },
      "link": { "color": { "text": "var(--wp--preset--color--accent)" } },
      "button": {
        "border": { "radius": "6px" },
        "color": { "background": "var(--wp--preset--color--accent)", "text": "#ffffff" },
        "spacing": { "padding": { "top": "10px", "bottom": "10px", "left": "18px", "right": "18px" } },
        "typography": { "fontWeight": "600" }
      }
    },
    "blocks": {
      "core/group": {
        "border": { "radius": "8px" }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
